{
  "homepage": "https://lifo123.github.io/lifo-library/",
  "name": "@lifo123/library",
  "version": "1.8.0",
  "description": "Lifo library",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lifo123/lifo-library.git"
  },
  "scripts": {
    "flifo:utils": "npx postcss src/styles/Main.css -o src/styles/output/Flifo.css --no-map",
    "noTailwind:styles": "tailwindcss -i src/styles/noTailwind.css -o src/styles/output/Flifo.noTailwind.pre.css --minify",
    "build": "pnpm run flifo:utils && tsc",
    "dev": "astro dev --host",
    "preview": "astro build && astro preview",
    "deploy": "pnpm run build && npm publish --access public",
    "deploy:pages": "astro check && astro build && gh-pages -d Build --dotfiles"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Lifo",
  "license": "ISC",
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.4.0",
    "@astrojs/tailwind": "^6.0.2",
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^22.9.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "astro": "^5.14.1",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "shx": "^0.4.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": "./dist/index.js",
    "./Stores": "./dist/Stores/index.js",
    "./utils": "./dist/utils/index.js"
  },
  "dependencies": {
    "@nanostores/react": "^1.0.0",
    "nanostores": "^1.0.1",
    "public-icons": "0.0.8"
  },
  "peerDependencies": {
    "@react-aria/utils": "^3.31.0",
    "react": "^18.2.0",
    "react-aria": "^3.44.0",
    "react-aria-components": "^1.13.0",
    "react-dom": "^18.2.0",
    "react-stately": "^3.42.0"
  }
}