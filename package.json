{
  "name": "@lifo123/library",
  "version": "1.9.6",
  "description": "Lifo library",
  "type": "module",
  "author": "Lifo",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lifo123/lifo-library.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./store": {
      "types": "./dist/Stores/index.d.ts",
      "import": "./dist/Stores/index.js",
      "require": "./dist/Stores/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    }
  },
  "scripts": {
    "flifo:css": "npx postcss src/styles/input.css -o src/styles/Flifo.css --no-map",
    "build": "pnpm run flifo:css && tsup",
    "deploy": "pnpm run build && npm publish --access public"
  },
  "dependencies": {
    "@react-aria/utils": "^3.34.0"
  },
  "peerDependencies": {
    "@nanostores/deepmap": ">=0.0.1",
    "@nanostores/react": ">=1.0.0",
    "lucide-react": ">=1.14.0",
    "motion": ">=12.23.26",
    "nanostores": ">=1.1.0",
    "react": ">=18",
    "react-aria": ">=3.44.0",
    "react-aria-components": ">=1.13.0",
    "react-dom": ">=18",
    "react-stately": ">=3.42.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nanostores/deepmap": "^0.0.1",
    "@nanostores/react": "^1.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "check-dts": "^0.9.0",
    "eslint": "^9.39.4",
    "motion": "^12.38.0",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "react": "^18.3.1",
    "react-aria": "^3.48.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^18.3.1",
    "react-stately": "^3.46.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
